}

\DeclareFieldFormat[treatyVolume]{volume}{#1\addspace}
\DeclareFieldFormat[treatyYear]{volume}{[#1]\addspace}
\DeclareFieldFormat[treatyVolume,treatyYear,treatyNumber]{series}{#1\addspace}
\DeclareFieldFormat[treatyVolume,treatyYear]{pages}{#1\addspace}
\DeclareFieldFormat[treatyYear]{number}{#1\addspace}
\DeclareFieldFormat[treatyNumber]{number}{No\addspace#1\addspace}

\newbibmacro{signed}{%
	\iffieldequalstr{type}{openIf}{%
		\printtext{opened for signature}\addspace\printorigdate}{%
		\iffieldequalstr{type}{openNif}{%
			\printtext{opened for signature\addspace\printorigdate}}{%
			\iffieldsequal{year}{origyear}{}{%
				\printtext{signed}\addspace\printorigdate}}}%
}

\newbibmacro{eif}{%
	\iffieldequalstr{type}{openIf}{%
		\printtext{entered into force}\addspace\printdate}{%
		\iffieldequalstr{type}{openNif}{%
			\printtext{not yet in force}}{%
			\iffieldsequal{year}{origyear}{%
				\printtext{signed and entered into force}\addspace\printdate}{%
				\printtext{not yet in force}}}}%
}

