	\printdate%
}

\DeclareFieldFormat[nongovtorder]{date}{\addspace{(at}\addspace#1)}

% Court practice directions and notes

\DeclareBibliographyAlias{pracnote}{misc}
\DeclareBibliographyAlias{pracnotevolume}{misc}
\DeclareBibliographyAlias{pracnoteyear}{misc}

\DeclareBibliographyDriver{pracnote}{%
	\printlist{institution}%
	\newunit%
	\printfield{type}%
	\addspace%
	\printfield{number}%
	\printtext{\textit{---}}%
	\addspace
	\printfield{title}%
	\newunit%
	\printdate%
}

\DeclareBibliographyDriver{pracnotevolume}{%
	\printlist{institution}%
	\newunit%
	\printfield{type}%
	\addspace%
	\printfield{number}%
	\printtext{\textit{---}}%
	\addspace
	\printfield{title}%
	\addspace%
	\usebibmacro{casereport}%
}

\DeclareBibliographyDriver{pracnoteyear}{%
	\printlist{institution}%
	\newunit%
	\printfield{type}%
	\addspace%
	\printfield{number}%
	\printtext{\textit{---}}%
	\addspace
	\printfield{title}%
	\addspace%
	\usebibmacro{casereport}%
}

\DeclareFieldFormat[pracnote,pracnotevolume,pracnoteyear]{type}{\textit{#1}}
\DeclareFieldFormat[pracnote,pracnotevolume,pracnoteyear]{number}{\textit{#1}\addspace}
\DeclareFieldFormat[pracnotevolume]{year}{(#1)}
\DeclareFieldFormat[pracnoteyear]{year}{[#1]}

% Journal articles

\DeclareBibliographyAlias{articlevolume}{article}
\DeclareBibliographyAlias{articleyear}{article}

\DeclareBibliographyDriver{article}{%
	\printfield{type}%
	\printnames{author}%
	\newunit%
	\printfield{title}%
	\addspace%
	\printfield{part}%
	\printfield{year}%
	\addspace%
	\printfield{volume}%
	\printfield{issue}%
	\printfield{journaltitle}%
	\printfield{pages}%
	\printfield{note}%
	\iffieldundef{postnote}{%
		\printfield{url}}{}%
}

\DeclareFieldFormat[articlevolume,articleyear]{title}{`#1'}
\DeclareFieldFormat[articlevolume,articleyear]{part}{(Pt\addspace#1)\addspace}
\DeclareFieldFormat[articlevolume]{year}{(#1)\addspace}
\DeclareFieldFormat[articleyear]{year}{[#1]\addspace}
\DeclareFieldFormat[articlevolume,articleyear]{issue}{(#1)}
\DeclareFieldFormat[articlevolume,articleyear]{journaltitle}{\addspace\textit{#1}\addspace}
\DeclareFieldFormat[articlevolume,articleyear]{note}{(#1)}

% Books

\DeclareBibliographyDriver{book}{%
	\usebibmacro{author}%
	\usebibmacro{editor}%
	\printfield{title}%
	\addspace%
	\printtext{(}%
	\printlist{publisher}%
	\newunit%
	\printfield{origyear}%
	\newunit%
	\usebibmacro{edition}%
	\printfield{year}%
	\printtext{)}%
	\printfield{volume}%
}

\DeclareBibliographyAlias{chapter}{incollection}

\DeclareBibliographyDriver{chapter}{%
	\usebibmacro{author}%
	\printfield{title}%
	\addspace%
	\printtext{in}%
	\addspace%
	\usebibmacro{editor}%
	\printfield{booktitle}%
	\addspace%
	\printtext{(}%
	\printlist{publisher}%
	\printfield{origyear}%
	\usebibmacro{edition}%
	\printfield{year}%
	\printtext{)}%
	\printfield{volume}%
	\printfield{pages}%
}

\DeclareBibliographyAlias{translatedbook}{book}

\DeclareBibliographyDriver{translatedbook}{%
	\usebibmacro{author}%
	\usebibmacro{editor}%
	\printfield{title}%
	\addspace%
	\printtext{(}%
	\printnames{translator}%
	\addspace%
	\printtext{trans}%
	\newunit%
	\printlist{publisher}%
	\newunit%
	\usebibmacro{edition}%
	\printfield{year}%
	\printtext{)}%
	\printfield{volume}%
	\iffieldundef{postnote}{%
		\addspace%
		\printtext{[trans of:}%
		\addspace%
		\printfield{origtitle}%
		\addspace\printtext{(}%
		\printtext{first published}\addspace\printfield{origyear}%
		\printtext{)]}}{}%
}

\DeclareFieldFormat[book,chapter]{origyear}{first\addspace{published}\addspace#1}
\DeclareFieldFormat[book,chapter]{year}{\iffieldundef{origyear}{#1}{#1\addspace{ed}}}
\DeclareFieldFormat[book,chapter,translatedbook]{edition}{\nth{#1}\addspace}
\DeclareFieldFormat[book,chapter,translatedbook]{volume}{\addspace{vol}\addspace#1}
\DeclareFieldFormat[chapter]{pages}{\addspace#1}
\DeclareFieldFormat[translatedbook]{origtitle}{\textit{#1}}

