\ProvidesFile{aglc.bbx}

\usepackage[T1]{fontenc}
\usepackage[australian]{babel}
% requires xelatex
%\usepackage{xeCJK}
\usepackage{url}
	\urlstyle{same}
\usepackage[style=british]{csquotes}
\usepackage[super]{nth}
\usepackage{etoolbox}
\usepackage{xstring}
\usepackage{textcomp}
\usepackage{gensymb}


\renewcommand{\newunitpunct}{,\addspace}

\DefineBibliographyStrings{australian}{%
	editor		=	{ed},
	editors		=	{eds},
	and			=	{and},
	andothers	=	{et\addspace{al}},
	edition		=	{ed}}
	
% If author(s), print and add comma, else print nothing.

\renewbibmacro{author}{%
	\ifnameundef{author}{}{%
		\printnames{author}%
		\addcomma\addspace}}
		
% If editor(s), print and add (ed) or (eds), else print nothing.
	
\renewbibmacro{editor}{%
	\ifnameundef{editor}{}{%
		\printnames{editor}%
		\addspace%
		\printtext{(}%
		\usebibmacro{editorstrg}%
		\printtext{)}%
		\addcomma\addspace}}
		
\renewbibmacro{translator}{%
	\ifnameundef{translator}{}{%
		\printnames{translator}%
		\addspace%
		\printtext{trans}%
		\addcomma\addspace}}
		
% Edition macro
		
\newbibmacro{edition}{%
	\iffieldundef{type}{%
		\iffieldundef{edition}{}{%
			\printfield{edition}\printtext{ed}\addcomma\addspace}}{%
		\printfield{edition}\printfield{type}\addspace\printtext{ed}\addcomma\addspace}}

% Case report macro
		
\newbibmacro{caseReport}{%
	\printfield{year}%
	\iffieldundef{volume}{}{\addspace}%
	\printfield{volume}%
	\addspace%
	\printfield{series}%
	\addspace%
	\printfield{pages}%
}
	
% Universal field formats for title, volume, pages, number and URL.

\DeclareFieldFormat{title}{\textit{#1}}
\DeclareFieldFormat{booktitle}{\textit{#1}}
\DeclareFieldFormat{volume}{#1}
\DeclareFieldFormat{pages}{#1}
\DeclareFieldFormat{url}{\addspace\textless\url{#1}\textgreater}
\DeclareFieldFormat{number}{\addspace{No}\addspace#1}
\DeclareFieldFormat{version}{#1}

% Australian cases and administrative decisions

\DeclareBibliographyAlias{caseGenVolume}{jurisdiction}
\DeclareBibliographyAlias{caseGenYear}{jurisdiction}
\DeclareBibliographyAlias{caseGenMnc}{jurisdiction}
\DeclareBibliographyAlias{caseGenUnreported}{jurisdiction}
\DeclareBibliographyAlias{caseTranscriptHca}{jurisdiction}

\DeclareBibliographyDriver{jurisdiction}{%
	\printfield{title}%
	\addspace%
	\usebibmacro{caseReport}%
}

\DeclareBibliographyDriver{caseGenMnc}{%
	\printfield{title}%
	\addspace%
	\printfield{year}%
	\printfield{venue}%
	\printfield{number}%
	\printdate%
}

\DeclareBibliographyDriver{caseGenUnreported}{%
	\printfield{title}%
	\addspace%
	\printtext{(Unreported}%
	\newunit%
	\printfield{venue}%
	\newunit%
	\printnames{author}%
	\newunit%
	\printdate%
	\printtext{)}%
}

\DeclareBibliographyDriver{caseTranscriptHca}{%
	\printtext{Transcript of Proceedings}%
	\newunit%
	\printfield{title}%
	\addspace%
	\printfield{year}%
	\addspace%
	\printtext{HCATrans}%
	\addspace%
	\printfield{number}%
	\printdate%
}

\DeclareFieldFormat[caseGenVolume]{year}{(#1)}
\DeclareFieldFormat[caseGenYear,caseGen-mnc,case-transcript-hca]{year}{[#1]}
\DeclareFieldFormat[caseGenMnc]{venue}{\addspace#1\addspace}
\DeclareFieldFormat[caseGenMnc,caseTranscript-hca]{number}{#1}
\DeclareFieldFormat[caseGenMnc,caseTranscript-hca]{date}{\addspace(#1)}

% Domestic arbitrations

\DeclareBibliographyAlias{arbitration}{jurisdiction}

\DeclareBibliographyDriver{arbitration}{%
	\printfield{title}%
	\iffieldundef{title}{}{\addspace\printtext{(}}%
	\printfield{note}%
	\newunit%
	\printfield{venue}%
	\newunit%
	\printfield{type}%
	\printfield{number}%
	\newunit%
	\printdate%		
	\iffieldundef{title}{}{\printtext{)}}%
}
	
% Transcripts of and submissions in court proceedings generally

\DeclareBibliographyAlias{caseTranscript}{jurisdiction}
\DeclareBibliographyAlias{caseSubmission}{jurisdiction}

\DeclareBibliographyDriver{caseTranscript}{%
	\printtext{Transcript of Proceedings}%
	\newunit%
	\printfield{title}%
	\addspace%
	\printtext{(}%
	\printfield{venue}%
	\newunit%
	\printfield{number}%
	\newunit%
	\printnames{author}%
	\newunit%
	\printdate%
	\printtext{)}%
}

\DeclareBibliographyDriver{caseSubmission}{%
	\printnames{author}%
	\newunit%
	\printfield{title}%
	\newunit%
	\printtext{Submission in}%
	\addspace%
	\printfield{maintitle}%
	\newunit%
	\printfield{number}%
	\newunit%
	\printdate%
}

\DeclareFieldFormat[caseTranscript,caseSubmission]{number}{#1}
\DeclareFieldFormat[caseSubmission]{title}{`#1'}

% Australian legislation

\DeclareBibliographyAlias{actGen}{legislation}
\DeclareBibliographyAlias{billGen}{legislation}
\DeclareBibliographyAlias{billGenExp}{legislation}

\DeclareBibliographyDriver{legislation}{%
	\printfield{type}%
	\printfield{origtitle}%
	\printfield{origyear}%
	\iffieldundef{origtitle}{}{\printtext{\addspace[}}%
	\printfield{title}%
	\printfield{year}%
	\iffieldundef{origtitle}{}{\printtext{]\addspace}}%
	\printlist{location}%
}

\DeclareFieldFormat[actGen]{origtitle}{\textit{#1}}
\DeclareFieldFormat[actGen]{origyear}{\addspace\textit{#1}}
\DeclareFieldFormat[actGen]{title}{\iffieldundef{origtitle}{\textit{#1}}{#1}}
\DeclareFieldFormat[actGen]{year}{\iffieldundef{origtitle}{\addspace\textit{#1}\addspace}{\addspace#1}}
\DeclareFieldFormat[billGen,billGenExp]{origtitle}{#1}
\DeclareFieldFormat[billGen,billGenExp]{origyear}{\addspace#1\addspace}
\DeclareFieldFormat[billGen,billGenExp]{title}{#1}
\DeclareFieldFormat[billGen,billGenExp]{year}{\addspace#1}
\DeclareListFormat[actGen,billGen,billGen-exp]{location}{\addspace(#1)}
\DeclareFieldFormat[billGenExp]{type}{#1\addcomma\addspace}

% Gazettes

\DeclareBibliographyAlias{gazette}{misc}

\DeclareBibliographyDriver{gazette}{%
	\usebibmacro{author}%
	\printfield{title}%
	\printlist{location}%
	\newunit%
	\printfield{maintitle}%
	\newunit%
	\printfield{number}%
	\newunit%
	\printdate%
	\newunit%
	\printfield{pages}%
}
	
\DeclareFieldFormat[gazette]{title}{`#1'\addspace{in}\addspace}

% Government orders and rulings

\DeclareBibliographyAlias{govtOrder}{misc}

\DeclareBibliographyDriver{govtOrder}{%
	\printnames{author}%
	\newunit%
	\printfield{title}%
	\newunit%
	\printfield{number}%
	\newunit%
	\printdate%
}

\DeclareFieldFormat[govtOrder]{number}{#1}

% Legislation delegated to nonGovernment entities

\DeclareBibliographyAlias{nonGovtOrder}{misc}

\DeclareBibliographyDriver{nonGovtOrder}{%
	\printnames{author}%
	\newunit%
	\printfield{title}%
	\printdate%
}

\DeclareFieldFormat[nonGovtOrder]{date}{\addspace{(at}\addspace#1)}

% Court practice directions and notes

\DeclareBibliographyAlias{pracnote}{misc}
\DeclareBibliographyAlias{pracnoteVolume}{misc}
\DeclareBibliographyAlias{pracnoteYear}{misc}

\DeclareBibliographyDriver{pracnote}{%
	\printlist{institution}%
	\newunit%
	\printfield{type}%
	\addspace%
	\printfield{number}%
	\printtext{\textit{---}}%
	\addspace
	\printfield{title}%
	\newunit%
	\printdate%
}

\DeclareBibliographyDriver{pracnoteVolume}{%
	\printlist{institution}%
	\newunit%
	\printfield{type}%
	\addspace%
	\printfield{number}%
	\printtext{\textit{---}}%
	\addspace
	\printfield{title}%
	\addspace%
	\usebibmacro{caseReport}%
}

\DeclareBibliographyDriver{pracnoteYear}{%
	\printlist{institution}%
	\newunit%
	\printfield{type}%
	\addspace%
	\printfield{number}%
	\printtext{\textit{---}}%
	\addspace
	\printfield{title}%
	\addspace%
	\usebibmacro{caseReport}%
}

\DeclareFieldFormat[pracnote,pracnoteVolume,pracnoteYear]{type}{\textit{#1}}
\DeclareFieldFormat[pracnote,pracnoteVolume,pracnoteYear]{number}{\textit{#1}\addspace}
\DeclareFieldFormat[pracnoteVolume]{year}{(#1)}
\DeclareFieldFormat[pracnoteYear]{year}{[#1]}

% Journal articles

\DeclareBibliographyAlias{articleVolume}{article}
\DeclareBibliographyAlias{articleYear}{article}

\DeclareBibliographyDriver{article}{%
	\printfield{type}%
	\printnames{author}%
	\newunit%
	\printfield{title}%
	\addspace%
	\printfield{part}%
	\printfield{year}%
	\addspace%
	\printfield{volume}%
	\printfield{issue}%
	\printfield{journaltitle}%
	\printfield{pages}%
	\printfield{note}%
	\iffieldundef{postnote}{%
		\printfield{url}}{}%
}

\DeclareFieldFormat[articleVolume,articleYear]{title}{`#1'}
\DeclareFieldFormat[articleVolume,articleYear]{part}{(Pt\addspace#1)\addspace}
\DeclareFieldFormat[articleVolume]{year}{(#1)\addspace}
\DeclareFieldFormat[articleYear]{year}{[#1]\addspace}
\DeclareFieldFormat[articleVolume,articleYear]{issue}{(#1)}
\DeclareFieldFormat[articleVolume,articleYear]{journaltitle}{\addspace\textit{#1}\addspace}
\DeclareFieldFormat[articleVolume,articleYear]{note}{(#1)}

% Books

\DeclareBibliographyDriver{book}{%
	\usebibmacro{author}%
	\usebibmacro{editor}%
	\printfield{title}%
	\addspace%
	\printtext{(}%
	\printlist{publisher}%
	\newunit%
	\printfield{origyear}%
	\newunit%
	\usebibmacro{edition}%
	\printfield{year}%
	\printtext{)}%
	\printfield{volume}%
}

\DeclareBibliographyAlias{chapter}{incollection}

\DeclareBibliographyDriver{chapter}{%
	\usebibmacro{author}%
	\printfield{title}%
	\addspace%
	\printtext{in}%
	\addspace%
	\usebibmacro{editor}%
	\printfield{booktitle}%
	\addspace%
	\printtext{(}%
	\printlist{publisher}%
	\printfield{origyear}%
	\usebibmacro{edition}%
	\printfield{year}%
	\printtext{)}%
	\printfield{volume}%
	\printfield{pages}%
}

\DeclareBibliographyAlias{translatedBook}{book}

\DeclareBibliographyDriver{translatedBook}{%
	\usebibmacro{author}%
	\usebibmacro{editor}%
	\printfield{title}%
	\addspace%
	\printtext{(}%
	\printnames{translator}%
	\addspace%
	\printtext{trans}%
	\newunit%
	\printlist{publisher}%
	\newunit%
	\usebibmacro{edition}%
	\printfield{year}%
	\printtext{)}%
	\printfield{volume}%
	\iffieldundef{postnote}{%
		\addspace%
		\printtext{[trans of:}%
		\addspace%
		\printfield{origtitle}%
		\addspace\printtext{(}%
		\printtext{first published}\addspace\printfield{origyear}%
		\printtext{)]}}{}%
}

\DeclareFieldFormat[book,chapter]{origyear}{first\addspace{published}\addspace#1}
\DeclareFieldFormat[book,chapter]{year}{\iffieldundef{origyear}{#1}{#1\addspace{ed}}}
\DeclareFieldFormat[book,chapter,translatedBook]{edition}{\nth{#1}\addspace}
\DeclareFieldFormat[book,chapter,translatedBook]{volume}{\addspace{vol}\addspace#1}
\DeclareFieldFormat[chapter]{pages}{\addspace#1}
\DeclareFieldFormat[translatedBook]{origtitle}{\textit{#1}}

