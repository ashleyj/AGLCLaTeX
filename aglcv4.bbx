\ProvidesFile{aglc.bbx}

\usepackage[T1]{fontenc}
\usepackage[australian]{babel}
% requires xelatex
% \usepackage{xeCJK}
\usepackage{url}
	\urlstyle{same}
\usepackage[style=british]{csquotes}
\usepackage[super]{nth}
\usepackage{etoolbox}
\usepackage{xstring}
\usepackage{textcomp}
\usepackage{gensymb}

\renewcommand{\newunitpunct}{,\addspace}

\DefineBibliographyStrings{australian}{%
	editor		=	{ed},
	editors		=	{eds},
	and			=	{and},
	andothers	=	{et\addspace{al}},
	edition		=	{ed}}
	
% If author(s), print and add comma, else print nothing.

\renewbibmacro{author}{%
	\ifnameundef{author}{}{%
		\printnames{author}%
		\addcomma\addspace}}
		
% If editor(s), print and add (ed) or (eds), else print nothing.
	
\renewbibmacro{editor}{%
	\ifnameundef{editor}{}{%
		\printnames{editor}%
		\addspace%
		\printtext{(}%
		\usebibmacro{editorstrg}%
		\printtext{)}%
		\addcomma\addspace}}
		
\renewbibmacro{translator}{%
	\ifnameundef{translator}{}{%
		\printnames{translator}%
		\addspace%
		\printtext{trans}%
		\addcomma\addspace}}
		
% Edition macro
		
\newbibmacro{edition}{%
	\iffieldundef{type}{%
		\iffieldundef{edition}{}{%
			\printfield{edition}\printtext{ed}\addcomma\addspace}}{%
		\printfield{edition}\printfield{type}\addspace\printtext{ed}\addcomma\addspace}}

% Case report macro
		
\newbibmacro{casereport}{%
	\printfield{year}%
	\iffieldundef{volume}{}{\addspace}%
	\printfield{volume}%
	\addspace%
	\printfield{series}%
	\addspace%
	\printfield{pages}%
}
	
% Universal field formats for title, volume, pages, number and URL.

\DeclareFieldFormat{title}{\textit{#1}}
\DeclareFieldFormat{booktitle}{\textit{#1}}
\DeclareFieldFormat{volume}{#1}
\DeclareFieldFormat{pages}{#1}
\DeclareFieldFormat{url}{\addspace\textless\url{#1}\textgreater}
\DeclareFieldFormat{number}{\addspace{No}\addspace#1}
\DeclareFieldFormat{version}{#1}

% Australian cases and administrative decisions

\DeclareBibliographyAlias{casegenvolume}{jurisdiction}
\DeclareBibliographyAlias{casegenyear}{jurisdiction}
\DeclareBibliographyAlias{casegenmnc}{jurisdiction}
\DeclareBibliographyAlias{casegenunreported}{jurisdiction}
\DeclareBibliographyAlias{casetranscripthca}{jurisdiction}

\DeclareBibliographyDriver{jurisdiction}{%
	\printfield{title}%
	\addspace%
	\usebibmacro{casereport}%
}

\DeclareBibliographyDriver{casegenmnc}{%
	\printfield{title}%
	\addspace%
	\printfield{year}%
	\printfield{venue}%
	\printfield{number}%
	\printdate%
}

\DeclareBibliographyDriver{casegenunreported}{%
	\printfield{title}%
	\addspace%
	\printtext{(Unreported}%
	\newunit%
	\printfield{venue}%
	\newunit%
	\printnames{author}%
	\newunit%
	\printdate%
	\printtext{)}%
}

\DeclareBibliographyDriver{casetranscripthca}{%
	\printtext{Transcript of Proceedings}%
	\newunit%
	\printfield{title}%
	\addspace%
	\printfield{year}%
	\addspace%
	\printtext{HCATrans}%
	\addspace%
	\printfield{number}%
	\printdate%
}

\DeclareFieldFormat[casegenvolume]{year}{(#1)}
\DeclareFieldFormat[casegenyear,casegenmnc,casetranscripthca]{year}{[#1]}
\DeclareFieldFormat[casegenmnc]{venue}{\addspace#1\addspace}
\DeclareFieldFormat[casegenmnc,casetranscripthca]{number}{#1}
\DeclareFieldFormat[casegenmnc,casetranscripthca]{date}{\addspace(#1)}

% Domestic arbitrations

\DeclareBibliographyAlias{arbitration}{jurisdiction}

\DeclareBibliographyDriver{arbitration}{%
	\printfield{title}%
	\iffieldundef{title}{}{\addspace\printtext{(}}%
	\printfield{note}%
	\newunit%
	\printfield{venue}%
	\newunit%
	\printfield{type}%
	\printfield{number}%
	\newunit%
	\printdate%		
	\iffieldundef{title}{}{\printtext{)}}%
}
	
% Transcripts of and submissions in court proceedings generally

\DeclareBibliographyAlias{casetranscript}{jurisdiction}
\DeclareBibliographyAlias{casesubmission}{jurisdiction}

\DeclareBibliographyDriver{casetranscript}{%
	\printtext{Transcript of Proceedings}%
	\newunit%
	\printfield{title}%
	\addspace%
	\printtext{(}%
	\printfield{venue}%
	\newunit%
	\printfield{number}%
	\newunit%
	\printnames{author}%
	\newunit%
	\printdate%
	\printtext{)}%
}

\DeclareBibliographyDriver{casesubmission}{%
	\printnames{author}%
	\newunit%
	\printfield{title}%
	\newunit%
	\printtext{Submission in}%
	\addspace%
	\printfield{maintitle}%
	\newunit%
	\printfield{number}%
	\newunit%
	\printdate%
}

\DeclareFieldFormat[casetranscript,casesubmission]{number}{#1}
\DeclareFieldFormat[casesubmission]{title}{`#1'}

% Australian legislation

\DeclareBibliographyAlias{actgen}{legislation}
\DeclareBibliographyAlias{billgen}{legislation}
\DeclareBibliographyAlias{billgenexp}{legislation}

\DeclareBibliographyDriver{legislation}{%
	\printfield{type}%
	\printfield{origtitle}%
	\printfield{origyear}%
	\iffieldundef{origtitle}{}{\printtext{\addspace[}}%
	\printfield{title}%
	\printfield{year}%
	\iffieldundef{origtitle}{}{\printtext{]\addspace}}%
	\printlist{location}%
}

\DeclareFieldFormat[actgen]{origtitle}{\textit{#1}}
\DeclareFieldFormat[actgen]{origyear}{\addspace\textit{#1}}
\DeclareFieldFormat[actgen]{title}{\iffieldundef{origtitle}{\textit{#1}}{#1}}
\DeclareFieldFormat[actgen]{year}{\iffieldundef{origtitle}{\addspace\textit{#1}\addspace}{\addspace#1}}
\DeclareFieldFormat[billgen,billgenexp]{origtitle}{#1}
\DeclareFieldFormat[billgen,billgenexp]{origyear}{\addspace#1\addspace}
\DeclareFieldFormat[billgen,billgenexp]{title}{#1}
\DeclareFieldFormat[billgen,billgenexp]{year}{\addspace#1}
\DeclareListFormat[actgen,billgen,billgenexp]{location}{\addspace(#1)}
\DeclareFieldFormat[billgenexp]{type}{#1\addcomma\addspace}

% Gazettes

\DeclareBibliographyAlias{gazette}{misc}

\DeclareBibliographyDriver{gazette}{%
	\usebibmacro{author}%
	\printfield{title}%
	\printlist{location}%
	\newunit%
	\printfield{maintitle}%
	\newunit%
	\printfield{number}%
	\newunit%
	\printdate%
	\newunit%
	\printfield{pages}%
}
	
\DeclareFieldFormat[gazette]{title}{`#1'\addspace{in}\addspace}

% Government orders and rulings

